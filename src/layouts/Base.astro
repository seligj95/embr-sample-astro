---
interface Props {
  title?: string;
}
const { title = "Embr × Astro" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <style is:global>
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        margin: 0;
        padding: 2rem;
        background: #0b0d12;
        color: #e7ecf3;
      }
      main { max-width: 820px; margin: 0 auto; }
      section.card {
        background: #141821;
        border: 1px solid #232936;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin: 1rem 0;
      }
      code { color: #9ecbff; }
      a { color: #7aa7ff; }
    </style>
  </body>
</html>
